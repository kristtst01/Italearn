{
  "id": "unit-02-lesson-02",
  "unit_id": "unit-02",
  "name": "He Is, She Is",
  "order": 2,
  "grammar_tips": [
    {
      "id": "unit-02-lesson-02-tip-01",
      "title": "The Third Person: è",
      "explanation": "'È' means both 'he is' and 'she is' — the verb form is the same. 'Lui è Marco' (he is Marco), 'Lei è Sara' (she is Sara). The accent on è is important: without it, 'e' just means 'and'.",
      "before_exercise": 0
    },
    {
      "id": "unit-02-lesson-02-tip-02",
      "title": "lei vs Lei — Same Sound, Different Meaning",
      "explanation": "'lei' (lowercase) = she. 'Lei' (capitalized) = you (formal). In speech they sound identical — context tells you which one. When a waiter says 'Lei è di Roma?' they're asking about YOU, not some woman named Roma.",
      "before_exercise": 6
    },
    {
      "id": "unit-02-lesson-02-tip-03",
      "title": "Questo è... Questa è... — Pointing at People",
      "explanation": "'Questo è Marco' = This is Marco. 'Questa è Sara' = This is Sara. 'Questo' for males, 'questa' for females. Don't overthink the pattern — it's just -o for him, -a for her. You'll see this pattern everywhere in Italian.",
      "before_exercise": 11
    }
  ],
  "exercises": [
