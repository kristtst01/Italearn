{
  "id": "unit-02-lesson-02",
  "unit_id": "unit-02",
  "name": "Essere: Singular",
  "order": 2,
  "grammar_tips": [
    {
      "id": "unit-02-lesson-02-tip-01",
      "title": "The Verb 'Essere' (To Be)",
      "explanation": "'Essere' is the most important Italian verb. It means 'to be' and is used to describe identity, nationality, profession, and origin. It's irregular — you need to memorize each form.",
      "table": [
        ["io", "sono"],
        ["tu", "sei"],
        ["lui/lei/Lei", "è"]
      ],
      "before_exercise": 0
    },
    {
      "id": "unit-02-lesson-02-tip-02",
      "title": "Sono — Double Duty",
      "explanation": "'Sono' means both 'I am' (io sono) and 'they are' (loro sono). Context always makes the meaning clear: 'Sono italiano' = I am Italian, 'Sono italiani' = They are Italian.",
      "before_exercise": 5
    },
    {
      "id": "unit-02-lesson-02-tip-03",
      "title": "The Accent on 'È'",
      "explanation": "'È' (with accent) means 'is'. Without the accent, 'e' means 'and'. The accent changes the meaning completely: 'Lui è italiano e lei è americana' = He is Italian and she is American.",
      "example": { "italian": "Lui è italiano e lei è americana.", "english": "He is Italian and she is American." },
      "before_exercise": 10
    }
  ],
  "exercises": [
