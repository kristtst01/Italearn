    {
      "id": "unit-02-lesson-08-tip-01",
      "title": "Unit 2 — Complete Introduction",
      "explanation": "You can now introduce yourself fully in Italian: give your name, nationality, country, and respond to both informal and formal questions. A complete informal introduction: 'Ciao, mi chiamo Marco. Sono italiano, di Roma. E tu?' Formal: 'Buongiorno, mi chiamo Marco. Sono italiano. Piacere!'",
      "example": { "italian": "Ciao, mi chiamo Marco. Sono italiano, di Roma. E tu?", "english": "Hi, my name is Marco. I'm Italian, from Rome. And you?" },
      "before_exercise": 0
    }
  ],
  "exercises": [
    {
      "id": "unit-02-lesson-08-ex-01",
      "type": "vocab",
      "subtype": "multiple_choice",
      "prompt": { "text": "Which form of essere completes 'Loro ___ spagnoli'?" },
      "sentence_context": "Loro sono spagnoli.",
      "correct_answer": "sono",
      "distractors": ["siamo", "siete", "è"],
      "hints": ["'Loro' uses the same form as 'io'."],
      "target_words": ["sono"]
    },
    {
      "id": "unit-02-lesson-08-ex-02",
      "type": "vocab",
      "subtype": "multiple_choice",
      "prompt": { "text": "Anna is a woman from England. What does she say?" },
      "sentence_context": "Sono inglese.",
      "correct_answer": "Sono inglese.",
      "distractors": ["Sono ingleso.", "Sono inglesa.", "Sono inglesi."],
      "hints": ["-e endings stay the same for both genders."],
      "target_words": ["inglese"]
    },
    {
