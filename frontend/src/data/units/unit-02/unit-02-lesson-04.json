  "grammar_tips": [
    {
      "id": "unit-02-lesson-04-tip-01",
      "title": "Mi Chiamo — Introducing Yourself",
      "explanation": "'Mi chiamo' literally means 'I call myself'. It's the standard way to say your name in Italian. To ask someone's name informally, say 'Come ti chiami?' (How do you call yourself?).",
      "example": { "italian": "Ciao, mi chiamo Anna. Come ti chiami?", "english": "Hi, my name is Anna. What's your name?" },
      "before_exercise": 0
    },
    {
      "id": "unit-02-lesson-04-tip-02",
      "title": "Sono Di... — Where You're From",
      "explanation": "'Sono di' + city name tells people where you're from: 'Sono di Roma' (I'm from Rome). To ask, use 'Di dove sei?' (informal) or 'Di dove è?' (formal).",
      "before_exercise": 5
    },
    {
      "id": "unit-02-lesson-04-tip-03",
      "title": "Professions and Gender",
      "explanation": "Like nationalities, Italian professions change by gender: 'studente' (m.) / 'studentessa' (f.), 'dottore' (m.) / 'dottoressa' (f.). Some modern professions keep the same form for both.",
      "before_exercise": 10
    }
  ],
