  "name": "Nationalities",
  "order": 4,
  "grammar_tips": [
    {
      "id": "unit-02-lesson-04-tip-01",
      "title": "Nationality Adjectives and Gender",
      "explanation": "Nationalities in Italian agree with the gender of the person. Most end in -o (masculine) or -a (feminine): italiano/italiana, americano/americana, spagnolo/spagnola. Some end in -e and stay the same for both genders: inglese, francese.",
      "table": [
        ["Masculine (-o)", "italiano, americano, spagnolo"],
        ["Feminine (-a)", "italiana, americana, spagnola"],
        ["Both genders (-e)", "inglese, francese"]
      ],
      "before_exercise": 0
    },
    {
      "id": "unit-02-lesson-04-tip-02",
      "title": "Sono + Nationality — No Article Needed",
      "explanation": "To say your nationality, use 'sono' + nationality adjective directly. No article! 'Sono italiano' = I am Italian. 'Sono americana' = I am American. The nationality also acts as an adjective when describing someone: 'È una ragazza italiana.'",
      "example": { "italian": "Sono italiano. E tu, sei americano?", "english": "I'm Italian. And you, are you American?" },
      "before_exercise": 8
    }
  ],
