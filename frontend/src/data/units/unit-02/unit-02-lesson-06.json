  "grammar_tips": [
    {
      "id": "unit-02-lesson-06-tip-01",
      "title": "Mi Chiamo — Introducing Yourself",
      "explanation": "'Mi chiamo' literally means 'I call myself'. It's the standard way to say your name. To ask informally: 'Come ti chiami?' (How do you call yourself?). The exchange goes: 'Come ti chiami?' — 'Mi chiamo Marco.'",
      "example": { "italian": "Ciao, mi chiamo Anna. Come ti chiami?", "english": "Hi, my name is Anna. What's your name?" },
      "before_exercise": 0
    },
    {
      "id": "unit-02-lesson-06-tip-02",
      "title": "E tu? — Bouncing the Question Back",
      "explanation": "After introducing yourself, 'E tu?' (And you?) invites the other person to respond. It's natural and common. Full exchange: 'Sono di Milano. E tu?' — 'Sono di Roma.'",
      "example": { "italian": "Sono di Milano. E tu?", "english": "I'm from Milan. And you?" },
      "before_exercise": 8
    }
  ],
