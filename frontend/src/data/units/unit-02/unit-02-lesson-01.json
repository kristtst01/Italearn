{
  "id": "unit-02-lesson-01",
  "unit_id": "unit-02",
  "name": "Subject Pronouns",
  "order": 1,
  "grammar_tips": [
    {
      "id": "unit-02-lesson-01-tip-01",
      "title": "Subject Pronouns in Italian",
      "explanation": "Italian has 7 subject pronouns: io (I), tu (you informal), lui (he), lei (she), Lei (you formal), noi (we), voi (you all), loro (they). Notice that 'lei' (she) and 'Lei' (you formal) are the same word — context tells you which is meant.",
      "before_exercise": 0
    },
    {
      "id": "unit-02-lesson-01-tip-02",
      "title": "Dropping the Pronoun",
      "explanation": "Unlike English, Italian often drops the subject pronoun because the verb ending tells you who is speaking. 'Sono italiano' already means 'I am Italian' — adding 'io' is optional emphasis.",
      "before_exercise": 5
    },
    {
      "id": "unit-02-lesson-01-tip-03",
      "title": "Tu vs. Voi",
      "explanation": "'Tu' is singular informal 'you'. 'Voi' is plural 'you' — use it when talking to a group. Remember: 'Lei' is formal singular 'you'.",
      "before_exercise": 10
    }
  ],
  "exercises": [
