{
  "id": "unit-02-lesson-01",
  "unit_id": "unit-02",
  "name": "I Am, You Are",
  "order": 1,
  "grammar_tips": [
    {
      "id": "unit-02-lesson-01-tip-01",
      "title": "Your First Real Verb",
      "explanation": "Until now, everything was memorized phrases. Now you learn how Italian verbs actually work. 'Essere' (to be) changes its form depending on who you're talking about. 'Io sono' = I am. 'Tu sei' = you are. This shape-shifting is called conjugation — and it's how Italian works.",
      "before_exercise": 0
    },
    {
      "id": "unit-02-lesson-01-tip-02",
      "title": "Drop the Pronoun",
      "explanation": "In English, 'I am Marco' needs the 'I'. In Italian, 'Sono Marco' is more natural than 'Io sono Marco'. The verb ending already tells you who's speaking. You only add the pronoun for emphasis or contrast: 'IO sono di Roma, TU sei di Milano.'",
      "before_exercise": 5
    },
    {
      "id": "unit-02-lesson-01-tip-03",
      "title": "Mi chiamo — A Chunk for Now",
      "explanation": "'Mi chiamo' literally means 'I call myself'. It's a reflexive verb, but don't worry about that yet — just memorize it as a chunk meaning 'my name is'. You'll learn how reflexive verbs actually work in a later unit.",
      "before_exercise": 10
    }
  ],
  "exercises": [
