  "grammar_tips": [
    {
      "id": "unit-02-lesson-05-tip-01",
      "title": "Country Names Use Definite Articles",
      "explanation": "Italian country names almost always use a definite article: l'Italia (f.), la Francia (f.), la Spagna (f.), la Germania (f.), l'Inghilterra (f.), il Brasile (m.), gli Stati Uniti (m. pl.). Most countries are feminine.",
      "table": [
        ["l'Italia", "Italy"],
        ["la Francia", "France"],
        ["la Spagna", "Spain"],
        ["la Germania", "Germany"],
        ["l'Inghilterra", "England/UK"],
        ["gli Stati Uniti", "USA"],
        ["il Brasile", "Brazil"]
      ],
      "before_exercise": 0
    },
    {
      "id": "unit-02-lesson-05-tip-02",
      "title": "'In' + Country — Drop the Article",
      "explanation": "To say you are in a country, drop the article: 'sono in Italia', 'vivo in Francia'. But when combined with 'di', just name the city and add the country: 'Sono di Roma, in Italia.'",
      "example": { "italian": "Sono di Roma, in Italia.", "english": "I'm from Rome, in Italy." },
      "before_exercise": 8
    }
  ],
