{
  "id": "unit-02-lesson-05",
  "unit_id": "unit-02",
  "name": "Review & Mix",
  "order": 5,
  "grammar_tips": [
    {
      "id": "unit-02-lesson-05-tip-01",
      "title": "Putting It All Together",
      "explanation": "You now know how to introduce yourself in Italian: say your name (mi chiamo), where you're from (sono di), your nationality, and what you do. Time to combine everything!",
      "before_exercise": 0
    },
    {
      "id": "unit-02-lesson-05-tip-02",
      "title": "Essere — Pick the Right Form",
      "explanation": "Remember to match 'essere' to the subject: io sono, tu sei, lui/lei è, noi siamo, voi siete, loro sono. The verb ending always tells you who's being talked about.",
      "table": [
        ["io", "sono"],
        ["tu", "sei"],
        ["lui/lei/Lei", "è"],
        ["noi", "siamo"],
        ["voi", "siete"],
        ["loro", "sono"]
      ],
      "before_exercise": 5
    },
    {
      "id": "unit-02-lesson-05-tip-03",
      "title": "A Typical Introduction",
      "explanation": "A natural Italian introduction sounds like: 'Ciao, mi chiamo Marco. Sono italiano, sono di Roma. Sono uno studente.' Short sentences, simple structure — you can do this!",
      "example": { "italian": "Ciao, mi chiamo Marco. Sono di Roma.", "english": "Hi, my name is Marco. I'm from Rome." },
      "before_exercise": 10
    }
  ],
  "exercises": [
    {
      "id": "unit-02-lesson-05-ex-01",
      "type": "vocab",
      "subtype": "multiple_choice",
      "prompt": {
        "text": "Someone says 'Come ti chiami?' — what are they asking?"
      },
      "sentence_context": "Ciao! Come ti chiami?",
      "correct_answer": "What is your name?",
      "distractors": [
        "How are you?",
        "Where are you from?",
        "What do you do?"
      ],
      "hints": [
        "'Chiami' comes from 'chiamare' — to call."
      ],
      "target_words": ["mi chiamo"]
    },
    {
      "id": "unit-02-lesson-05-ex-02",
      "type": "vocab",
      "subtype": "multiple_choice",
      "prompt": {
        "text": "Which form of 'essere' completes: 'Loro ___ spagnoli'?"
      },
      "sentence_context": "Loro sono spagnoli.",
      "correct_answer": "sono",
      "distractors": [
        "siamo",
        "siete",
        "è"
      ],
      "hints": [
        "'Loro' uses the same form as 'io'."
      ],
      "target_words": ["sono"]
    },
    {
