  "name": "Formal Introductions",
  "order": 7,
  "grammar_tips": [
    {
      "id": "unit-02-lesson-07-tip-01",
      "title": "Formal 'You' — Lei",
      "explanation": "Italian has two words for 'you': 'tu' (informal, friends/family) and 'Lei' (formal, strangers/authority). 'Lei' uses the SAME verb form as lui/lei (third person singular). Always capitalize formal 'Lei'. Formal vs informal: 'Di dove sei?' (informal) → 'Di dov'è?' (formal).",
      "table": [
        ["Informal", "tu sei", "di dove sei?", "come ti chiami?"],
        ["Formal", "Lei è", "di dov'è?", "come si chiama?"]
      ],
      "before_exercise": 0
    },
    {
      "id": "unit-02-lesson-07-tip-02",
      "title": "Piacere — Nice to Meet You",
      "explanation": "'Piacere' (pleasure/nice to meet you) is said when meeting someone for the first time. You can respond with 'piacere mio' (my pleasure) or simply 'piacere' again. It's used in both formal and informal situations.",
      "example": { "italian": "Mi chiamo Marco. Piacere! — Piacere mio, mi chiamo Sofia.", "english": "My name is Marco. Nice to meet you! — My pleasure, my name is Sofia." },
      "before_exercise": 8
    }
  ],
