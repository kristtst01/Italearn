  "grammar_tips": [
    {
      "id": "unit-02-lesson-03-tip-01",
      "title": "Essere — Full Conjugation",
      "explanation": "Now you know all six forms of 'essere'. Here's the complete picture:",
      "table": [
        [
          "io",
          "sono"
        ],
        [
          "tu",
          "sei"
        ],
        [
          "lui/lei/Lei",
          "è"
        ],
        [
          "noi",
          "siamo"
        ],
        [
          "voi",
          "siete"
        ],
        [
          "loro",
          "sono"
        ]
      ],
      "before_exercise": 0
    },
    {
      "id": "unit-02-lesson-03-tip-02",
      "title": "Nationalities and Gender",
      "explanation": "Most Italian nationalities change based on gender: 'americano' (m.) / 'americana' (f.). But some ending in -e stay the same for both: 'inglese' (English) works for both men and women.",
      "example": {
        "italian": "Lui è inglese, lei è inglese.",
        "english": "He is English, she is English."
      },
      "before_exercise": 5
    },
    {
      "id": "unit-02-lesson-03-tip-03",
      "title": "Plural Nationalities",
      "explanation": "For groups: -o → -i (americani, italiani, spagnoli), -a → -e (americane, italiane, spagnole), -e → -i (inglesi). The plural form must match the group's gender.",
      "before_exercise": 10
    }
  ],
  "exercises": [
