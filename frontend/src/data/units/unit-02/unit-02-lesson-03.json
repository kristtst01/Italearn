{
  "id": "unit-02-lesson-03",
  "unit_id": "unit-02",
  "name": "The Full Picture",
  "order": 3,
  "grammar_tips": [
    {
      "id": "unit-02-lesson-03-tip-01",
      "title": "Three New Pronouns, Three New Forms",
      "explanation": "'Noi siamo' = we are. 'Voi siete' = you (plural) are. 'Loro sono' = they are. Notice that 'sono' does double duty — it means both 'I am' (io sono) AND 'they are' (loro sono). Context always makes it clear which one.",
      "before_exercise": 0
    },
    {
      "id": "unit-02-lesson-03-tip-02",
      "title": "The Full Essere Table",
      "explanation": "Here's the complete picture: io sono, tu sei, lui/lei è, noi siamo, voi siete, loro sono. Six forms, but 'sono' covers two of them. That leaves just five unique forms to memorize. Not bad for the most important verb in Italian.",
      "table": [
        ["Pronoun", "Essere", "English"],
        ["io", "sono", "I am"],
        ["tu", "sei", "you are"],
        ["lui/lei", "è", "he/she is"],
        ["noi", "siamo", "we are"],
        ["voi", "siete", "you (plural) are"],
        ["loro", "sono", "they are"]
      ],
      "before_exercise": 5
    },
    {
      "id": "unit-02-lesson-03-tip-03",
      "title": "Professions with Essere",
      "explanation": "To say what someone does, use essere: 'Sono studente' (I'm a student), 'Lei è dottoressa' (She's a doctor). In Italian you can drop the article ('un/una') with professions — both 'Sono un insegnante' and 'Sono insegnante' work.",
      "before_exercise": 11
    }
  ],
