{
  "id": "unit-05-lesson-01",
  "unit_id": "unit-05",
  "name": "I Have, You Have",
  "order": 1,
  "grammar_tips": [
    {
      "id": "unit-05-lesson-01-tip-01",
      "title": "Your Second Verb",
      "explanation": "'Avere' (to have) is the second most important Italian verb after essere. Like essere, it changes form depending on who's speaking: 'ho' (I have), 'hai' (you have), 'ha' (he/she has). With essere and avere together, you can already say a lot.",
      "before_exercise": 0
    },
    {
      "id": "unit-05-lesson-01-tip-02",
      "title": "The Silent H",
      "explanation": "Ho, hai, ha all start with a silent H — you never pronounce it. The H exists only for spelling: 'ho' (I have) vs 'o' (or), 'hai' (you have) vs 'ai' (to the), 'ha' (has) vs 'a' (to/at). In speech, context makes it clear.",
      "before_exercise": 6
    },
    {
      "id": "unit-05-lesson-01-tip-03",
      "title": "Have vs Be",
      "explanation": "Don't confuse avere with essere! 'Sono Marco' (I AM Marco) = identity. 'Ho un cane' (I HAVE a dog) = possession. If you're describing what something IS, use essere. If you're talking about what someone HAS, use avere.",
      "before_exercise": 12
    }
  ],
