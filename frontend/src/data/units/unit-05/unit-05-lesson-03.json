{
  "id": "unit-05-lesson-03",
  "unit_id": "unit-05",
  "name": "How Old Are You?",
  "order": 3,
  "grammar_tips": [
    {
      "id": "unit-05-lesson-03-tip-01",
      "title": "I Have 25 Years",
      "explanation": "In English you say 'I am 25 years old.' In Italian, you say 'Ho venticinque anni' — literally 'I have 25 years.' Age always uses avere, never essere! To ask someone's age: 'Quanti anni hai?' (How many years do you have?).",
      "before_exercise": 0
    },
    {
      "id": "unit-05-lesson-03-tip-02",
      "title": "Don't Forget Anni!",
      "explanation": "You can't just say 'Ho venti' for 'I'm 20.' You need 'anni' (years): 'Ho venti anni.' When the tens number ends in a vowel before 'anni', they can merge in writing: trent'anni (30), quarant'anni (40). But 'venti anni' stays as two words.",
      "before_exercise": 7
    }
  ],
