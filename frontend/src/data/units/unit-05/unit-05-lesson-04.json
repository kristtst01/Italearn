{
  "id": "unit-05-lesson-04",
  "unit_id": "unit-05",
  "name": "Avere Idioms",
  "order": 4,
  "grammar_tips": [
    {
      "id": "unit-05-lesson-04-tip-01",
      "title": "I Have Hunger, Not I Am Hungry",
      "explanation": "Italian uses avere for many feelings where English uses 'to be': ho fame (I'm hungry), ho sete (I'm thirsty), ho freddo (I'm cold), ho caldo (I'm hot), ho sonno (I'm sleepy), ho paura (I'm scared). It's always avere + noun, with NO article: 'Ho fame' — NOT 'Ho la fame.'",
      "before_exercise": 0
    },
    {
      "id": "unit-05-lesson-04-tip-02",
      "title": "Don't Say Sono!",
      "explanation": "English speakers constantly say *'Sono freddo' when they mean 'Ho freddo.' Be careful: 'Sono freddo' actually means 'I am a cold/distant person' — very different from feeling chilly! Same trap with all these expressions: use avere, never essere.",
      "before_exercise": 7
    },
    {
      "id": "unit-05-lesson-04-tip-03",
      "title": "I Need, I Feel Like, I'm in a Hurry",
      "explanation": "Three more useful avere expressions: 'Ho bisogno di...' (I need...), 'Ho voglia di...' (I feel like...), 'Ho fretta' (I'm in a hurry). Notice 'bisogno' and 'voglia' need 'di' before what you need or want: 'Ho bisogno di acqua.' 'Ho voglia di un caffè.'",
      "before_exercise": 12
    }
  ],
