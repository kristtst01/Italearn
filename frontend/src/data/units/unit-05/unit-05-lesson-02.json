{
  "id": "unit-05-lesson-02",
  "unit_id": "unit-05",
  "name": "We Have, They Have",
  "order": 2,
  "grammar_tips": [
    {
      "id": "unit-05-lesson-02-tip-01",
      "title": "The Full Picture",
      "explanation": "Now you know all of avere: ho (I have), hai (you have), ha (he/she has), abbiamo (we have), avete (you all have), hanno (they have). Like essere, the endings tell you who — so pronouns are optional.",
      "before_exercise": 0
    },
    {
      "id": "unit-05-lesson-02-tip-02",
      "title": "Hanno vs Anno",
      "explanation": "'Hanno' (they have) and 'anno' (year) sound almost identical. The H is silent — it's only there for spelling. Even Italian kids mix these up! Context makes it obvious: 'Hanno un cane' (they have) vs 'un anno' (one year).",
      "before_exercise": 6
    },
    {
      "id": "unit-05-lesson-02-tip-03",
      "title": "Essere or Avere?",
      "explanation": "These two verbs show up side by side constantly. Keep the contrast clear: 'Siamo studenti' (we ARE students — identity) vs 'Abbiamo un libro' (we HAVE a book — possession). When in doubt: IS something → essere. HAS something → avere.",
      "before_exercise": 11
    }
  ],
