{
  "id": "unit-01-lesson-04",
  "unit_id": "unit-01",
  "name": "When You're Lost",
  "order": 4,
  "grammar_tips": [
    {
      "id": "unit-01-lesson-04-tip-01",
      "title": "Your Two Lifelines",
      "explanation": "When a conversation moves too fast, you have two essential tools: 'Non capisco' (I don't understand) to signal the problem, and 'Può ripetere?' (Can you repeat?) to ask for help. Use them freely — Italians appreciate the effort more than they judge the struggle.",
      "before_exercise": 0
    },
    {
      "id": "unit-01-lesson-04-tip-02",
      "title": "Come si dice...? — Learn Mid-Conversation",
      "explanation": "'Come si dice...?' means 'How do you say...?' It lets you learn new words right inside a conversation. Point at something and ask 'Come si dice questo in italiano?' (How do you say this in Italian?) — and you'll get a mini lesson on the spot.",
      "before_exercise": 5
    },
    {
      "id": "unit-01-lesson-04-tip-03",
      "title": "Va bene vs. D'accordo",
      "explanation": "Both mean 'okay', but they feel different. 'Va bene' is relaxed — 'alright, fine'. 'D'accordo' emphasizes agreement — 'agreed, deal'. You'll hear 'va bene' more in casual conversation and 'd'accordo' when confirming plans.",
      "before_exercise": 10
    }
  ],
  "exercises": [
    {
      "id": "unit-01-lesson-04-ex-01",
      "type": "vocab",
      "subtype": "multiple_choice",
      "prompt": { "text": "Someone speaks too fast and you're lost. What do you say?" },
      "sentence_context": "Non capisco. Più lentamente, per favore.",
      "correct_answer": "Non capisco",
      "distractors": ["Va bene", "D'accordo", "Grazie"],
      "hints": ["'Capisco' = I understand. 'Non' makes it negative."],
      "target_words": ["non capisco"]
    },
    {
      "id": "unit-01-lesson-04-ex-02",
      "type": "vocab",
      "subtype": "multiple_choice",
      "prompt": { "text": "What does 'può ripetere?' mean?" },
      "sentence_context": "Scusi, può ripetere?",
      "correct_answer": "Can you repeat? (formal)",
      "distractors": ["Can you speak? (formal)", "Can you understand?", "Can you help me?"],
      "hints": ["'Può' = can you (formal), 'ripetere' = to repeat."],
      "target_words": ["può ripetere"]
    },
    {
      "id": "unit-01-lesson-04-ex-03",
      "type": "vocab",
      "subtype": "multiple_choice",
      "prompt": { "text": "You want to know the Italian word for something. What do you ask?" },
      "sentence_context": "Come si dice 'water' in italiano?",
      "correct_answer": "Come si dice...?",
      "distractors": ["Non capisco", "Può ripetere?", "Va bene?"],
      "hints": ["Literally: 'How does one say...?' — the magic phrase for learning on the fly."],
      "target_words": ["come si dice"]
    },
    {
      "id": "unit-01-lesson-04-ex-04",
      "type": "vocab",
      "subtype": "multiple_choice",
      "prompt": { "text": "What does 'va bene' mean?" },
      "sentence_context": "Va bene, ci vediamo alle otto!",
      "correct_answer": "Okay / Alright",
      "distractors": ["I understand", "I'm sorry", "See you later"],
      "hints": ["Literally: 'it goes well'. Used like English 'alright' or 'fine'."],
      "target_words": ["va bene"]
    },
    {
      "id": "unit-01-lesson-04-ex-05",
      "type": "vocab",
      "subtype": "multiple_choice",
      "prompt": { "text": "Your colleague proposes a meeting time. You want to confirm you agree. What do you say?" },
      "sentence_context": "D'accordo, alle dieci.",
      "correct_answer": "D'accordo",
      "distractors": ["Va bene", "Non capisco", "Mi dispiace"],
      "hints": ["This word emphasizes agreement — like 'agreed' or 'deal'. Same root as English 'accord'."],
      "target_words": ["d'accordo"]
    },
