{
  "id": "unit-01-lesson-01",
  "unit_id": "unit-01",
  "name": "Hello & Goodbye",
  "order": 1,
  "grammar_tips": [
    {
      "id": "unit-01-lesson-01-tip-01",
      "title": "Two Worlds: Formal and Informal",
      "explanation": "Every Italian interaction splits into formal or informal. Use 'ciao' with friends and family. Use 'buongiorno' or 'buonasera' with strangers, elders, or anyone you'd call 'Sir' or 'Ma'am'. Getting this right matters — Italians notice immediately.",
      "before_exercise": 0
    },
    {
      "id": "unit-01-lesson-01-tip-02",
      "title": "Greeting by the Clock",
      "explanation": "'Buongiorno' covers morning through early afternoon. 'Buonasera' takes over from late afternoon onward. But 'buonanotte' is NOT a greeting — it's only for bedtime, like saying 'sleep well'. You would never walk into a restaurant at 9 PM and say 'buonanotte'.",
      "before_exercise": 5
    },
    {
      "id": "unit-01-lesson-01-tip-03",
      "title": "Salve — Your Safety Net",
      "explanation": "Not sure if someone is a 'ciao' person or a 'buongiorno' person? Say 'salve'. It works at any time, in any register — perfectly neutral. From Latin, meaning 'be well'.",
      "before_exercise": 10
    }
  ],
  "exercises": [
    {
      "id": "unit-01-lesson-01-ex-01",
      "type": "vocab",
      "subtype": "multiple_choice",
      "prompt": { "text": "What does 'ciao' mean?" },
      "sentence_context": "Ciao, Marco!",
      "correct_answer": "Hello / Goodbye (informal)",
      "distractors": ["Good morning (formal)", "Good night", "See you again"],
      "hints": ["This word pulls double duty — it works for both arriving and leaving. But only with people you know well."],
      "target_words": ["ciao"]
    },
    {
      "id": "unit-01-lesson-01-ex-02",
      "type": "vocab",
      "subtype": "multiple_choice",
      "prompt": { "text": "What does 'buongiorno' mean?" },
      "sentence_context": "Buongiorno, signora!",
      "correct_answer": "Good morning / Good day",
      "distractors": ["Good evening", "Good night", "Hello (informal)"],
      "hints": ["Two parts: 'buon' (good) + 'giorno' (day)."],
      "target_words": ["buongiorno"]
    },
    {
