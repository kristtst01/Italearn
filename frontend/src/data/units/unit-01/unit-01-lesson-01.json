        "text": "What does 'ciao' mean?"
      },
      "sentence_context": "Ciao, come stai?",
      "correct_answer": "Hello and goodbye (informal)",
      "distractors": [
        "Good morning",
        "Good night",
        "Thank you"
      ],
      "hints": [
        "Think about how Italians greet friends — this word pulls double duty."
      ],
      "target_words": [
        "ciao"
      ]
