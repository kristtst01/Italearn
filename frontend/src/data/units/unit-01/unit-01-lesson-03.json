{
  "id": "unit-01-lesson-03",
  "unit_id": "unit-01",
  "name": "How Are You?",
  "order": 3,
  "grammar_tips": [
    {
      "id": "unit-01-lesson-03-tip-01",
      "title": "Stai vs. Sta — Informal and Formal Again",
      "explanation": "'Come stai?' is informal (friends). 'Come sta?' is formal (strangers, elders). Same split as 'ciao' vs 'buongiorno' and 'scusa' vs 'scusi'. This pattern runs through ALL of Italian — get used to it!",
      "example": { "italian": "Buongiorno, professore. Come sta?", "english": "Good morning, professor. How are you?" },
      "before_exercise": 0
    },
    {
      "id": "unit-01-lesson-03-tip-02",
      "title": "Stare, Not Essere",
      "explanation": "To say how you feel, Italian uses 'stare' — NOT 'essere'. 'Sto bene' (I'm well) is correct. 'Sono bene' is WRONG. For now just memorize 'sto bene' and 'sto male' as chunks — the full verb comes later.",
      "before_exercise": 6
    },
    {
      "id": "unit-01-lesson-03-tip-03",
      "title": "Always Ask Back",
      "explanation": "In Italian, answering 'How are you?' without asking back is rude. Always add 'e tu?' (informal) or 'e Lei?' (formal). The full pattern: Bene, grazie, e tu? (Well, thanks, and you?)",
      "before_exercise": 10
    }
  ],
  "exercises": [
