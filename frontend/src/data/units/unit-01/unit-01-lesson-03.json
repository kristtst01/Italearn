      "type": "vocab",
      "subtype": "multiple_choice",
      "prompt": {
        "text": "'Come stai?' is used in which context?"
      },
      "sentence_context": "Ciao Marco, come stai?",
      "correct_answer": "Informal — with friends, family, peers",
      "distractors": [
        "Formal — with strangers or elders",
        "Only in the morning",
        "Only when someone is sick"
      ],
      "hints": [
        "'Stai' uses the 'tu' form of the verb."
      ],
      "target_words": [
        "come stai"
      ]
    },
