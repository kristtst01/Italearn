{
  "id": "unit-01-lesson-02",
  "unit_id": "unit-01",
  "name": "Please & Thank You",
  "order": 2,
  "grammar_tips": [
    {
      "id": "unit-01-lesson-02-tip-01",
      "title": "Scusi vs. Scusa — The Formal/Informal Split Again",
      "explanation": "Just like 'ciao' vs 'buongiorno', Italian splits 'excuse me' into formal and informal. 'Scusi' for strangers and formal situations. 'Scusa' for friends. When in doubt, use 'scusi' — being too polite is never a problem.",
      "before_exercise": 0
    },
    {
      "id": "unit-01-lesson-02-tip-02",
      "title": "Permesso — A Word English Doesn't Have",
      "explanation": "'Permesso' is said when you physically need to pass through or enter someone's space. On a crowded bus, pushing through a doorway, entering someone's home — say 'permesso'. It's like 'coming through' but polite. There's no exact English equivalent.",
      "before_exercise": 6
    },
    {
      "id": "unit-01-lesson-02-tip-03",
      "title": "Prego Does Everything",
      "explanation": "'Prego' is the reply to 'grazie' (you're welcome), but Italians use it for much more. A waiter hands you the menu: 'Prego.' Someone asks if they can sit: 'Prego!' (Please, go ahead.) It's Italian for 'help yourself'.",
      "before_exercise": 10
    }
  ],
  "exercises": [
