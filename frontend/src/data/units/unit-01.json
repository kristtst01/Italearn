  {
    "id": "unit-01-lesson-02",
    "unit_id": "unit-01",
    "name": "Polite Phrases",
    "order": 2,
    "grammar_tips": [
      "'Scusi' (formal) and 'scusa' (informal) both mean 'excuse me', but you use 'scusi' with strangers and in formal situations, and 'scusa' with friends.",
      "'Permesso' is a special word used when you need to physically pass through or enter a room — it's like saying 'may I come through?'",
      "'Prego' is the standard reply to 'grazie'. It can also mean 'please, go ahead' when offering something."
    ],
    "exercises": [
      {
        "id": "unit-01-lesson-02-ex-01",
        "type": "vocab",
        "subtype": "multiple_choice",
        "prompt": {
          "text": "What does 'grazie' mean?"
        },
        "sentence_context": "Grazie mille!",
        "correct_answer": "Thank you",
        "distractors": [
          "Please",
          "I'm sorry",
          "Goodbye"
        ],
        "hints": [
          "One of the first words every Italian learner picks up."
        ],
        "target_words": [
          "grazie"
        ]
      },
      {
        "id": "unit-01-lesson-02-ex-02",
        "type": "vocab",
        "subtype": "multiple_choice",
