        },
        "sentence_context": "Un caffè, per favore.",
        "correct_answer": "Per favore",
        "distractors": [
          "Prego",
          "Grazie",
          "Permesso"
        ],
        "hints": [
          "Literally means 'as a favor'."
        ],
        "target_words": [
          "per favore"
