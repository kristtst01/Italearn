[
  {
    "id": "unit-01-lesson-01",
    "unit_id": "unit-01",
    "name": "Hello & Goodbye",
    "order": 1,
    "grammar_tips": [
      "Italian has both formal and informal greetings. Use 'ciao' with friends and family, and 'buongiorno' or 'buonasera' in formal situations or with strangers.",
      "'Ciao' is unique — it works as both 'hello' and 'goodbye', but only in informal settings.",
      "'Salve' is a safe middle ground when you're unsure whether to be formal or informal. It works at any time of day."
    ],
    "exercises": [
      {
        "id": "unit-01-lesson-01-ex-01",
        "type": "vocab",
        "subtype": "multiple_choice",
        "prompt": {
          "text": "What does 'ciao' mean?"
        },
        "sentence_context": "Ciao, come stai?",
        "correct_answer": "Hello and goodbye (informal)",
        "distractors": [
          "Good morning",
          "Good night",
          "Thank you"
        ],
        "hints": [
          "Think about how Italians greet friends — this word pulls double duty."
        ],
        "target_words": [
          "ciao"
        ]
      },
      {
        "id": "unit-01-lesson-01-ex-02",
        "type": "vocab",
        "subtype": "multiple_choice",
        "prompt": {
          "text": "It's 9 AM and you walk into a café. Which greeting is most appropriate?"
        },
        "sentence_context": "Buongiorno, un caffè per favore.",
        "correct_answer": "Buongiorno",
        "distractors": [
          "Buonasera",
          "Buonanotte",
          "Arrivederci"
        ],
        "hints": [
          "This greeting is used from morning until early afternoon."
        ],
        "target_words": [
          "buongiorno"
        ]
