  {
    "id": "unit-01-lesson-04",
    "unit_id": "unit-01",
    "name": "Basic Responses",
    "order": 4,
    "grammar_tips": [
      "'Può ripetere?' uses the formal 'Lei' form of 'potere' (can). For informal situations, you'd say 'Puoi ripetere?'",
      "'Come si dice...?' literally means 'How does one say...?' — the 'si' makes it impersonal. This is one of the most useful phrases for language learners.",
      "'Va bene' and 'd'accordo' both mean 'okay', but 'va bene' is more casual (like 'alright') while 'd'accordo' emphasizes agreement (like 'agreed')."
    ],
    "exercises": [
      {
        "id": "unit-01-lesson-04-ex-01",
        "type": "vocab",
        "subtype": "multiple_choice",
        "prompt": {
          "text": "What does 'va bene' mean?"
        },
        "sentence_context": "Va bene, ci vediamo domani.",
