{
  "id": "unit-03-lesson-03",
  "unit_id": "unit-03",
  "name": "Numbers 21–100",
  "order": 3,
  "grammar_tips": [
    {
      "id": "unit-03-lesson-03-tip-01",
      "title": "Tens: 20 to 100",
      "explanation": "The tens follow a pattern echoing single digits: venti (20), trenta (30), quaranta (40), cinquanta (50), sessanta (60), settanta (70), ottanta (80), novanta (90), cento (100).",
      "table": [
        [
          "20",
          "venti"
        ],
        [
          "30",
          "trenta"
        ],
        [
          "40",
          "quaranta"
        ],
        [
          "50",
          "cinquanta"
        ],
        [
          "60",
          "sessanta"
        ],
        [
          "70",
          "settanta"
        ],
        [
          "80",
          "ottanta"
        ],
        [
          "90",
          "novanta"
        ],
        [
          "100",
          "cento"
        ]
      ],
      "before_exercise": 0
    },
    {
      "id": "unit-03-lesson-03-tip-02",
      "title": "Combining Tens and Units",
      "explanation": "Attach the digit to the ten: venti + uno = ventuno, venti + due = ventidue. When adding 'uno' or 'otto', drop the final vowel of the ten: vent-uno (not ventiuno), vent-otto (not ventiotto).",
      "example": {
        "italian": "Ho ventuno anni.",
        "english": "I am twenty-one years old."
      },
      "before_exercise": 5
    },
    {
      "id": "unit-03-lesson-03-tip-03",
      "title": "Accent on 'Tre' Compounds",
      "explanation": "When 'tre' is added to a ten, it gets an accent: ventitré, trentatré, quarantatré, etc. This is the only digit that changes when combined with a ten.",
      "example": {
        "italian": "Ho trentatré anni.",
        "english": "I am thirty-three years old."
      },
      "before_exercise": 10
    }
  ],
