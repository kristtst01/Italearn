  "name": "One and Many",
  "order": 3,
  "grammar_tips": [
    {
      "id": "unit-03-lesson-03-tip-01",
      "title": "Making Things Plural",
      "explanation": "Italian plurals change the ending: -o becomes -i (libro → libri), -a becomes -e (penna → penne), -e becomes -i (chiave → chiavi). No 's' at the end like English — the vowel does the work.",
      "table": [
        ["Singular ending", "Plural ending", "Example"],
        ["-o", "-i", "libro → libri"],
        ["-a", "-e", "penna → penne"],
        ["-e", "-i", "chiave → chiavi"]
      ],
      "before_exercise": 0
    },
    {
      "id": "unit-03-lesson-03-tip-02",
      "title": "Plural Articles: i, gli, le",
      "explanation": "'Il' becomes 'i' in the plural: il libro → i libri. 'Lo' becomes 'gli': lo studente → gli studenti. 'La' becomes 'le': la penna → le penne. 'L'' becomes 'gli' (masculine) or 'le' (feminine): l'uomo → gli uomini, l'acqua → le acque.",
      "table": [
        ["Singular", "Plural", "Example"],
        ["il", "i", "i libri"],
        ["lo", "gli", "gli studenti"],
        ["l' (masc)", "gli", "gli uomini"],
        ["la", "le", "le penne"],
        ["l' (fem)", "le", "le amiche"]
      ],
      "before_exercise": 7
    },
    {
      "id": "unit-03-lesson-03-tip-03",
      "title": "Watch Out: amico → amici, amica → amiche",
      "explanation": "Nouns ending in -co/-ca keep the hard 'k' sound in the plural by adding an 'h': amico → amici (the 'ci' is already a 'ch' sound), but amica → amiche (the 'h' preserves the hard 'k'). 'Uomo → uomini' is flat-out irregular — just memorize it.",
      "before_exercise": 13
    }
  ],
