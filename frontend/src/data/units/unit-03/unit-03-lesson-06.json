{
  "id": "unit-03-lesson-06",
  "unit_id": "unit-03",
  "name": "Indefinite Articles",
  "order": 6,
  "grammar_tips": [
    {
      "id": "unit-03-lesson-06-tip-01",
      "title": "The Four Indefinite Articles",
      "explanation": "Italian has four words for 'a/an'. The choice depends on the gender and first sound of the noun: 'un' before most masculine nouns, 'uno' before masculine nouns starting with s+consonant or z, 'una' before feminine nouns starting with a consonant, 'un'' before feminine nouns starting with a vowel.",
      "table": [
        [
          "un",
          "masculine (un libro, un amico)"
        ],
        [
          "uno",
          "masc. before s+cons/z (uno zaino, uno studente)"
        ],
        [
          "una",
          "feminine (una casa, una donna)"
        ],
        [
          "un'",
          "fem. before vowel (un'amica, un'idea)"
        ]
      ],
      "before_exercise": 0
    },
    {
      "id": "unit-03-lesson-06-tip-02",
      "title": "Un' Needs an Apostrophe",
      "explanation": "'Un'' (with apostrophe) is only for feminine nouns starting with a vowel: un'amica, un'idea. Before masculine nouns starting with a vowel, use 'un' (no apostrophe): un amico. The apostrophe signals a dropped 'a' from 'una'.",
      "example": {
        "italian": "Ho un amico e un'amica.",
        "english": "I have a (male) friend and a (female) friend."
      },
      "before_exercise": 8
    }
  ],
