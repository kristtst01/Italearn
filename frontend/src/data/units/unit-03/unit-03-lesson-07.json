{
  "id": "unit-03-lesson-07",
  "unit_id": "unit-03",
  "name": "Age & Avere Idioms",
  "order": 7,
  "grammar_tips": [
    {
      "id": "unit-03-lesson-07-tip-01",
      "title": "Age — 'Avere' Not 'Essere'",
      "explanation": "Italian uses avere for age: 'Ho venti anni' = I am twenty years old. To ask: 'Quanti anni hai?' (informal) or 'Quanti anni ha?' (formal). Never use essere for age!",
      "example": {
        "italian": "Quanti anni hai? — Ho venticinque anni.",
        "english": "How old are you? — I am twenty-five years old."
      },
      "before_exercise": 0
    },
    {
      "id": "unit-03-lesson-07-tip-02",
      "title": "Avere for Physical Sensations",
      "explanation": "Italian uses avere where English uses 'to be' for physical states. Literally you 'have' hunger, thirst, etc.",
      "table": [
        [
          "ho fame",
          "I'm hungry"
        ],
        [
          "ho sete",
          "I'm thirsty"
        ],
        [
          "ho freddo",
          "I'm cold"
        ],
        [
          "ho caldo",
          "I'm hot"
        ],
        [
          "ho sonno",
          "I'm sleepy"
        ]
      ],
      "before_exercise": 8
    }
  ],
