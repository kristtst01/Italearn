{
  "id": "unit-03-lesson-05",
  "unit_id": "unit-03",
  "name": "Avere: abbiamo, avete, hanno",
  "order": 5,
  "grammar_tips": [
    {
      "id": "unit-03-lesson-05-tip-01",
      "title": "Avere — Full Conjugation",
      "explanation": "Now you know all six forms of avere. The plural forms are: abbiamo (we have), avete (you all have), hanno (they have). Notice 'hanno' starts with a silent H.",
      "table": [
        [
          "io",
          "ho"
        ],
        [
          "tu",
          "hai"
        ],
        [
          "lui/lei/Lei",
          "ha"
        ],
        [
          "noi",
          "abbiamo"
        ],
        [
          "voi",
          "avete"
        ],
        [
          "loro",
          "hanno"
        ]
      ],
      "before_exercise": 0
    },
    {
      "id": "unit-03-lesson-05-tip-02",
      "title": "Pro-Drop with Avere",
      "explanation": "As with essere, subject pronouns are often dropped with avere: 'Abbiamo un cane' = 'We have a dog'. The verb ending tells you who the subject is.",
      "example": {
        "italian": "Abbiamo un gatto e hanno un cane.",
        "english": "We have a cat and they have a dog."
      },
      "before_exercise": 8
    }
  ],
