  "grammar_tips": [
    {
      "id": "unit-03-lesson-08-tip-01",
      "title": "More Avere Idioms",
      "explanation": "More sensations and states use avere in Italian.",
      "table": [
        [
          "ho paura",
          "I'm afraid"
        ],
        [
          "ho ragione",
          "I'm right"
        ],
        [
          "ho torto",
          "I'm wrong"
        ],
        [
          "ho bisogno di",
          "I need"
        ]
      ],
      "before_exercise": 0
    },
    {
      "id": "unit-03-lesson-08-tip-02",
      "title": "Ragione vs Torto — Opposites",
      "explanation": "'Avere ragione' = to be right, 'avere torto' = to be wrong. They are exact opposites and always used with avere, never essere. 'Hai ragione!' = You're right! 'Hai torto!' = You're wrong!",
      "example": {
        "italian": "Hai ragione, non ho torto.",
        "english": "You are right, I am not wrong."
      },
      "before_exercise": 8
    }
  ],
