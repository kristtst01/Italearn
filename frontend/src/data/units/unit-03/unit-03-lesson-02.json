  "grammar_tips": [
    {
      "id": "unit-03-lesson-02-tip-01",
      "title": "Numbers 11–20",
      "explanation": "Numbers 11–16 attach the digit after 'dici': undici (11), dodici (12), tredici (13), quattordici (14), quindici (15), sedici (16). For 17–19 it reverses: diciassette (17), diciotto (18), diciannove (19). Twenty is venti.",
      "table": [
        [
          "11",
          "undici"
        ],
        [
          "12",
          "dodici"
        ],
        [
          "13",
          "tredici"
        ],
        [
