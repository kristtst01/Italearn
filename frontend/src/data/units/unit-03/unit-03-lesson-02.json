          "17",
          "diciassette"
        ],
        [
          "18",
          "diciotto"
        ],
        [
          "19",
          "diciannove"
        ],
        [
          "20",
          "venti"
        ]
      ],
      "before_exercise": 0
    },
    {
      "id": "unit-03-lesson-02-tip-02",
      "title": "Spelling Traps: diciotto and diciannove",
      "explanation": "Watch the spelling: diciotto (not 'diciassotto') drops a letter, and diciannove has double 'n'. Say them out loud — the rhythm helps: di-ciot-to, di-cia-nno-ve.",
      "example": {
        "italian": "Ho diciotto anni.",
        "english": "I am eighteen years old."
      },
      "before_exercise": 8
    }
  ],
