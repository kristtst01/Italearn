  "grammar_tips": [
    {
      "id": "unit-03-lesson-01-tip-01",
      "title": "Italian Numbers 0–10",
      "explanation": "Italian numbers 0–10 are unique words you need to memorize: zero, uno, due, tre, quattro, cinque, sei, sette, otto, nove, dieci.",
      "table": [
        [
          "0",
          "zero"
        ],
        [
          "1",
          "uno"
        ],
        [
          "2",
          "due"
        ],
        [
          "3",
          "tre"
        ],
        [
          "4",
          "quattro"
        ],
        [
          "5",
          "cinque"
        ],
        [
          "6",
          "sei"
        ],
        [
          "7",
          "sette"
        ],
        [
          "8",
          "otto"
        ],
        [
          "9",
          "nove"
        ],
        [
          "10",
          "dieci"
        ]
      ],
      "before_exercise": 0
    },
    {
      "id": "unit-03-lesson-01-tip-02",
      "title": "'Sei' — Six or You Are?",
      "explanation": "'Sei' means both 'six' (number) and 'you are' (verb essere). Context makes it clear: 'Ho sei gatti' = I have six cats. 'Tu sei italiano' = You are Italian.",
      "example": {
        "italian": "Ho sei gatti.",
        "english": "I have six cats."
      },
      "before_exercise": 8
    }
  ],
