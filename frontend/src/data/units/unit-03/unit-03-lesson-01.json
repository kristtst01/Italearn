{
  "id": "unit-03-lesson-01",
  "unit_id": "unit-03",
  "name": "Masculine & Feminine",
  "order": 1,
  "grammar_tips": [
    {
      "id": "unit-03-lesson-01-tip-01",
      "title": "Every Noun Has a Gender",
      "explanation": "In Italian, every noun is either masculine or feminine — even objects. A book is masculine (libro), a pen is feminine (penna). There's no 'it'. This feels strange, but it's the foundation of everything in Italian grammar.",
      "before_exercise": 0
    },
    {
      "id": "unit-03-lesson-01-tip-02",
      "title": "The -o / -a Rule",
      "explanation": "Most nouns ending in -o are masculine. Most nouns ending in -a are feminine. This covers about 70% of Italian nouns. Exceptions exist, but learn the rule first — it's your best instinct.",
      "table": [
        ["Ending", "Gender", "Example"],
        ["-o", "Masculine", "libro, tavolo, telefono"],
        ["-a", "Feminine", "penna, sedia, borsa"]
      ],
      "before_exercise": 4
    },
    {
      "id": "unit-03-lesson-01-tip-03",
      "title": "Un and Una — Your First Articles",
      "explanation": "'Un' goes with masculine nouns: un libro (a book). 'Una' goes with feminine nouns: una penna (a pen). English has just 'a/an' — Italian makes you pick based on gender. Get this right and every future grammar topic gets easier.",
      "before_exercise": 9
    }
  ],
