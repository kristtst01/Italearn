{
  "id": "unit-03-lesson-04",
  "unit_id": "unit-03",
  "name": "Things Around Me",
  "order": 4,
  "grammar_tips": [
    {
      "id": "unit-03-lesson-04-tip-01",
      "title": "C'è and Ci sono — There Is / There Are",
      "explanation": "'C'è' means 'there is' (singular). 'Ci sono' means 'there are' (plural). These are the most natural way to describe what's in a space: 'C'è un libro sul tavolo' (there's a book on the table), 'Ci sono due sedie' (there are two chairs).",
      "before_exercise": 0
    },
    {
      "id": "unit-03-lesson-04-tip-02",
      "title": "Rooms of the House",
      "explanation": "Now that you can name objects and use articles, let's place them in real rooms. La cucina (kitchen), il bagno (bathroom), la camera (bedroom), il giardino (garden). Notice the gender — you already know the rule: -a is usually feminine, -o is usually masculine.",
      "before_exercise": 6
    },
    {
      "id": "unit-03-lesson-04-tip-03",
      "title": "Everything Together",
      "explanation": "You now have the full toolkit: gender, articles (all 7 definite + 4 indefinite), plurals, and c'è/ci sono. Every Italian sentence about objects uses this system. From here on, every new noun you learn comes with its article — that's how natives learn too.",
      "before_exercise": 13
    }
  ],
