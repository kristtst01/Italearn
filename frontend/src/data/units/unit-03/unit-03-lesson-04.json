{
  "id": "unit-03-lesson-04",
  "unit_id": "unit-03",
  "name": "Avere: ho, hai, ha",
  "order": 4,
  "grammar_tips": [
    {
      "id": "unit-03-lesson-04-tip-01",
      "title": "Avere — To Have (Singular Forms)",
      "explanation": "'Avere' means 'to have'. The three singular forms are: ho (I have), hai (you have), ha (he/she/you-formal have). All three start with a silent H.",
      "table": [
        [
          "io",
          "ho"
        ],
        [
          "tu",
          "hai"
        ],
        [
          "lui/lei/Lei",
          "ha"
        ]
      ],
      "before_exercise": 0
    },
    {
      "id": "unit-03-lesson-04-tip-02",
      "title": "The Silent H",
      "explanation": "The H in ho, hai, ha, hanno is always silent. It's there only to distinguish these words in writing: ho (I have) vs o (or), ha (he has) vs a (to/at), hanno (they have) vs anno (year). Never pronounce it!",
      "example": {
        "italian": "Hai un cane o un gatto?",
        "english": "Do you have a dog or a cat?"
      },
      "before_exercise": 8
    }
  ],
