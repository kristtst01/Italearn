  "grammar_tips": [
    {
      "id": "unit-04-lesson-02-tip-01",
      "title": "Two Groups of Teens",
      "explanation": "Numbers 11-16 each have a unique form you need to memorize: undici, dodici, tredici, quattordici, quindici, sedici. Notice the pattern — the unit digit comes first, then '-dici' (from dieci). But each one is slightly irregular, so treat them as individual words.",
      "before_exercise": 0
    },
    {
      "id": "unit-04-lesson-02-tip-02",
      "title": "The Flipped Teens: 17-19",
      "explanation": "Numbers 17-19 flip the pattern: 'dici' (ten) comes FIRST, then the unit. Dici + sette = diciassette (17). Dici + otto = diciotto (18). Dici + nove = diciannove (19). Notice the double letters: diciassette (ss), diciannove (nn). Diciotto drops the 'i' because otto starts with 'o'.",
      "before_exercise": 8
    }
  ],
