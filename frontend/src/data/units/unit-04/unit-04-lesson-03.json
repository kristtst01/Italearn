{
  "id": "unit-04-lesson-03",
  "unit_id": "unit-04",
  "name": "Numbers 21-100",
  "order": 3,
  "grammar_tips": [
    {
      "id": "unit-04-lesson-03-tip-01",
      "title": "The Pattern: Tens + Units",
      "explanation": "After 20, Italian numbers are predictable: take the tens word (venti, trenta, quaranta...) and add the unit. Venti + due = ventidue (22). Trenta + tre = trentatré (33). You already know all the units from lesson 1 — now you just combine them.",
      "before_exercise": 0
    },
    {
      "id": "unit-04-lesson-03-tip-02",
      "title": "Drop the Vowel Before Uno and Otto",
      "explanation": "When adding 'uno' or 'otto' to a tens word, the final vowel of the tens drops: venti + uno = ventuno (NOT ventiuno), venti + otto = ventotto (NOT ventiotto). This happens because Italian avoids clashing vowels. The same rule applies to all tens: trentuno, trentotto, quarantuno, etc.",
      "before_exercise": 6
    },
    {
      "id": "unit-04-lesson-03-tip-03",
      "title": "Tre Gets an Accent",
      "explanation": "When 'tre' is added to a tens word, it takes an accent: ventitré, trentatré, quarantatré. The accent marks where the stress falls. On its own, 'tre' has no accent — only when it's part of a compound number.",
      "before_exercise": 12
    }
  ],
