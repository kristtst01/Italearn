  "name": "Numbers 0-10",
  "order": 1,
  "grammar_tips": [
    {
      "id": "unit-04-lesson-01-tip-01",
      "title": "11 Unique Words",
      "explanation": "Italian numbers 0-10 are each a unique word — there are no patterns to help you. You just have to memorize them. The good news: once you know these 11 words, the rest of the number system is built from them.",
      "before_exercise": 0
    },
    {
      "id": "unit-04-lesson-01-tip-02",
      "title": "Sei = Six AND You Are",
      "explanation": "'Sei' means both 'six' and 'you are' (from essere). Context always makes it clear: 'Sei di Roma?' (you are) vs 'Ho sei libri' (six). Italian is full of words that do double duty — you'll get used to it.",
      "before_exercise": 8
    }
  ],
